{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build LISP Interpreter",
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++17",
                "-g",
                "main.cpp",
                "tokenizer.cpp",
                "parser.cpp",
                "-o",
                "lisp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}